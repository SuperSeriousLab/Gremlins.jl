# .github/workflows/mutation.yml.example
#
# GitHub Actions recipe for Gremlins mutation gate.
#
# Copy to .github/workflows/mutation.yml in your package repo.
# Adjust GREMLINS_REF and threshold flags to taste.
#
# Strategy:
# - On every PR, detect which .jl source files changed.
# - Run gremlins-cli with --files scoped to changed files only (fast).
# - Fail the PR if kill rate is below --acceptable threshold.
# - Full-package run can be scheduled nightly (see commented section below).

name: Mutation Gate

on:
  pull_request:
    paths:
      - 'src/**/*.jl'

jobs:
  mutation:
    name: Mutation testing (changed files)
    runs-on: ubuntu-latest
    timeout-minutes: 60

    steps:
      - name: Checkout package
        uses: actions/checkout@v4
        with:
          fetch-depth: 0   # needed for git diff

      - name: Checkout Gremlins
        uses: actions/checkout@v4
        with:
          repository: YOUR-ORG/Gremlins.jl   # update to your fork/org
          ref: main                            # or a specific tag
          path: .gremlins

      - name: Set up Julia
        uses: julia-actions/setup-julia@v2
        with:
          version: '1.10'

      - name: Cache Julia packages
        uses: julia-actions/cache@v2

      - name: Install Gremlins dependencies
        run: julia --project=.gremlins -e 'using Pkg; Pkg.instantiate()'

      - name: Install package dependencies
        run: julia --project=. -e 'using Pkg; Pkg.instantiate()'

      - name: Detect changed Julia source files
        id: changed
        run: |
          # Find .jl files changed vs base branch (src/ only, not test/)
          CHANGED=$(git diff --name-only origin/${{ github.base_ref }}...HEAD \
            | grep '^src/.*\.jl$' \
            | tr '\n' ',' \
            | sed 's/,$//')
          echo "files=${CHANGED}" >> $GITHUB_OUTPUT
          echo "Changed src files: ${CHANGED}"

      - name: Run mutation gate
        if: steps.changed.outputs.files != ''
        run: |
          julia --project=.gremlins .gremlins/bin/gremlins-cli.jl \
            --pkg ${{ github.workspace }} \
            --files "${{ steps.changed.outputs.files }}" \
            --test-file runtests.jl \
            --warm \
            --strong 0.80 \
            --acceptable 0.60 \
            --json mutation-report.json
        # Exit 0 = strong or acceptable; Exit 1 = weak (PR fails); Exit 2 = infra error

      - name: No changed source files
        if: steps.changed.outputs.files == ''
        run: echo "No changed src/*.jl files in this PR — mutation gate skipped."

      - name: Upload mutation report
        if: always() && steps.changed.outputs.files != ''
        uses: actions/upload-artifact@v4
        with:
          name: mutation-report
          path: mutation-report.json
          if-no-files-found: ignore

# ─── Optional: nightly full-package run ───────────────────────────────────────
